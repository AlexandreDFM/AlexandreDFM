# Ignore Git files
.git

# Ignore node modules and build artifacts
node_modules
.next

# Ignore build output
dist
build

# Ignore pnpm store
.pnpm-store

# Ignore environment variable files
.env*
.env.local
.env.*.local

# Logs files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS generated files
.DS_Store
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Other files to ignore
*.pem
.vercel
